# Base domain for all services (e.g., myapp.example.local)
BASE_DOMAIN=localhost

# Git remote URL for config sync (optional)
# GIT_REMOTE=git@github.com:username/env-configs.git

# 32-byte secret used to encrypt stored repository credentials (e.g. GitHub PAT).
# Without it, "Connect to GitHub" returns "encryption key not set" and tokens
# cannot be saved. Generate with: tr -dc 'A-Za-z0-9' </dev/urandom | head -c 32
# Rotating this key invalidates every previously stored token.
# CREDENTIAL_KEY=

# === Security knobs ============================================================

# LAB_MODE=true (default) opens read-only API endpoints and WS log streams to
# anyone on the LAN — convenient for a homelab. Set false for any deployment
# reachable from networks you don't fully trust; Bearer auth then applies to
# every endpoint, with WS streams accepting the token via ?token= query param.
# LAB_MODE=true

# === License (sold-product builds only) =======================================
# Off by default — leave commented out for personal / homelab use.
#
# When you sell this product, generate a keypair once with:
#   envm license gen-keypair
# Embed LICENSE_PUBLIC_KEY in the customer's compose file and keep
# LICENSE_PRIVATE_KEY in your secret manager. Issue per-customer licenses with:
#   envm license issue --to "Acme" --days 365 --private-key "$LICENSE_PRIVATE_KEY"
# Then ship the .lic file to the customer; they drop it at LICENSE_FILE.
#
# LICENSE_ENFORCE=false
# LICENSE_PUBLIC_KEY=
# LICENSE_FILE=/app/data/license.lic
