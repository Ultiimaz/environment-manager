# Base domain for all services (e.g., myapp.example.local)
BASE_DOMAIN=localhost

# Git remote URL for config sync (optional)
# GIT_REMOTE=git@github.com:username/env-configs.git

# 32-byte secret used to encrypt stored repository credentials (e.g. GitHub PAT).
# Without it, "Connect to GitHub" returns "encryption key not set" and tokens
# cannot be saved. Generate with: tr -dc 'A-Za-z0-9' </dev/urandom | head -c 32
# Rotating this key invalidates every previously stored token.
# CREDENTIAL_KEY=
